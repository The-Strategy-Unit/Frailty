          subtitle = "Across all places affected by the FIC") +
  scale_colour_manual(name = "Type", 
                      values = c("Observed" = "lightblue",
                                 "Counterfactual" = "red"))

```

### Reduced average length of stay for people living with frailty

The average length of stay for people living with frailty is the total number of completed days in hospital by patients with a HFRS of five or higher on admission, divided by the number of admissions to hospital by people with a HFRS of five or higher on admission.

```{r, include = FALSE}

apc_los_summary <- read.csv("../3b_Analysed_Outputs/los_summary.csv")
tau_hat <- readRDS("../3b_Analysed_Outputs/los_tau_hat.RDS")

library(synthdid)

se = sqrt(vcov(tau_hat, method='jackknife'))[1,1]
z = tau_hat[1]/se
p6 = 2 * (1-pnorm(abs(z)))
```

In the period after the FIC was introduced, the average affected place, during the average month, had an average hospital length of stay of `r signif(apc_los_summary$apc_los[2], 3)` completed days. It is estimated that without the FIC, the average affected place, during the average month, would have instead had an average hospital length of stay of `r signif(apc_los_summary$apc_los[2] + tau_hat[1], 3)` completed days.

A difference larger than this was observed in `r round(100*p6, 2)`% of the placebo tests, indicating that this difference could be due to modelling uncertainty rather than any true impact of the FIC.

The chart below shows the actual average hospital length of stay by people living with frailty (in blue) relative to the estimated number of hospital days that would have happened without the FIC (in red). The vertical black line indicates when the programme was introduced.

```{r, echo = FALSE}

plot(tau_hat, 
     overlay = 1, 
     se.method = "none",
     control.name='Counterfactual', 
     treated.name='Observed', 
     effect.alpha=0, 
     onset.alpha=1, 
     trajectory.alpha=1, 
     lambda.comparable=FALSE) + 
  scale_y_continuous(name = "Average length of stay in hospital") + 
  scale_x_continuous(name = "Date", 
                     breaks = c(0,20,40,60,80), 
                     labels = c("Apr 2019", 
                                "Nov 2020", 
                                "Jul 2022", 
                                "Mar 2024", 
                                "Nov 2025")) + 
  ggtitle("Average hospital length of stay for people living with frailty", 
          subtitle = "Across all places affected by the FIC")
```

### Proportionally more discharges to usual place of residence for people living with frailty

Discharges to usual place of residence was defined as the number of patients with a HFRS of five or higher on admission who were discharged to their usual place of residence, as a proportion of all discharged patients who had a HSF of five or higher on admission. Note that a number of patients were excluded from this analysis entirely due to having discharge location which was primarily caused by external circumstances - for example if their discharge location was a forced repatriation or was unknown.

```{r, include = FALSE}

output7 <- read_csv(
  file = "../3b_Analysed_Outputs/discharges_by_residence_impact.csv")

aggr_output7 <- Aggregate_Central_Binomial(output7)

placebos7 <- read_csv(
  file = "../3b_Analysed_Outputs/discharges_by_residence_placebos.csv"
)

aggr_placebos7 <- Aggregate_Placebos_Binomial(placebos = placebos7,
                                             iter = iterations)

p_value7 <- 100*mean(abs(aggr_output7$scaled_effect) < abs(aggr_placebos7$scaled_effect))

cf7 <- read_csv(
  file = "../3b_Analysed_Outputs/discharges_by_residence_cf.csv")

```

In the period after the FIC was introduced, the average affected place, during the average month, had `r format(signif(aggr_output7$trials/aggr_output7$unit_timepoints, 3), scientific = FALSE, big.mark = ",")` discharges by people living with frailty. Of these, `r format(signif(100*(aggr_output7$obs_success/aggr_output7$trials), 3), scientific = FALSE, big.mark = ",")`% were discharged to their usual place of residence. It is estimated that without the FIC, the average affected place, during the average month, would have instead had `r format(signif(100*(aggr_output7$cf_success/aggr_output7$trials), 3), scientific = FALSE, big.mark = ",")`% were discharged to their usual place of residence.

A difference larger than this was observed in `r round(p_value7, 2)`% of the placebo tests, indicating that this difference could be due to modelling uncertainty rather than any true impact of the FIC.

The chart below shows the actual percentage of people living with frailty who were discharged to their usual place of residence (in blue) relative to the estimated percentage of people living with frailty who were discharged to their usual place of residence that would have happened without the FIC (in red). The vertical black line indicates when the programme was introduced.

```{r, echo = FALSE}

cf7 |> 
  ggplot(mapping = aes(x = zoo::as.yearmon(YearMon))) + 
  geom_line(mapping = aes(y = 100*(actual_sum/trials_sum), 
                          col = "Observed")) +
  geom_line(mapping = aes(y = 100*(predicted_sum/trials_sum),
                          col = "Counterfactual")) +
  scale_x_continuous("Month") + 
  scale_y_continuous("Discharges to usual place of residence (%)", 
                     labels = scales::label_number()) + 
  geom_vline(xintercept = zoo::as.yearmon("Apr 2025")) + 
  theme_minimal() + 
  ggtitle("Percentage of people living with frailty discharged to their usual place of residence", 
          subtitle = "Across all places affected by the FIC") +
  scale_colour_manual(name = "Type", 
                      values = c("Observed" = "blue",
                                 "Counterfactual" = "red"))
```

### Summary

Of the seven outcomes evaluated, there was a statistically significant impact of the FIC detected in `r sum(c(p_value1,p_value2,p_value3,p_value4,p_value5,p6*100,p_value7)>95)` of them.

For all of the outcomes, it appeared that the model was able to create broadly accurate predictions of the what the outcome would have been without the intervention in the pre-FIC period. This is a fairly limited test, but nonetheless is one suggestive piece of evidence that the method is working as desired.

